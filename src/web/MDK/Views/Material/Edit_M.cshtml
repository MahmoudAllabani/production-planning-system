
@model MDK.Models.Ham_Madde

@{
    ViewBag.Title = "Güncelle";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hammadde Güncelle</title>
    <link rel="stylesheet" href="~/purple/assets/vendors/mdi/css/materialdesignicons.min.css">
    <link rel="stylesheet" href="~/purple/assets/vendors/css/vendor.bundle.base.css">
    <link rel="stylesheet" href="~/purple/assets/css/style.css" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<div class="loader"></div>
<div class="app-container app-theme-white body-tabs-shadow fixed-sidebar fixed-header">
    <div class="app-main__outer">
        <div class="app-main__inner">
            <div class="col-md-8 grid-margin stretch-card">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title mb-2">Hammadde Güncelle</h4>
                        <p class="card-description mb-4">Hammadde bilgilerini güncelleyiniz</p>

                        @using (Html.BeginForm("Edit_M", "Material", FormMethod.Post, new { id = "editForm" }))
                        {
                            @Html.HiddenFor(model => model.Id)

                            <div class="row g-3 mb-4">
                                <div class="col-md-6">
                                    @Html.LabelFor(model => model.Ham_Madde1, "Hammadde Adı", new { @class = "form-label" })
                                    @Html.TextBoxFor(model => model.Ham_Madde1, new { @class = "form-control", required = "required", maxlength = "32" })
                                </div>

                                <div class="col-md-6">
                                    @Html.Label("Birim Seç", new { @class = "form-label" })
                                    @Html.DropDownListFor(model => model.Birim_FK,
                                        new SelectList(ViewBag.Birimler, "Id", "Birim1", Model.Birim_FK),
                                        "Birim Seçiniz",
                                        new { @class = "form-select", required = "required" })
                                </div>
                            </div>

                            <hr class="my-4 border-top border-2 border-secondary" />
                            <button type="submit" class="btn btn-gradient-primary">Kaydet</button>
                        }

                        <script>
                            document.getElementById("editForm").addEventListener("submit", function (event) {
                                event.preventDefault();
                                var form = event.target;

                                Swal.fire({
                                    title: "Başarılı!",
                                    text: "Hammadde başarıyla güncellendi.",
                                    icon: "success",
                                    showConfirmButton: false,
                                    timer: 2000
                                }).then(function () {
                                    form.submit();
                                });
                            });
                        </script>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>