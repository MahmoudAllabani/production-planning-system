
@model MDK.Models.Kategori
@{
    ViewBag.Title = "Kategori Ekle";
}

<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kategori Kaydı</title>
    <link rel="stylesheet" href="~/purple/assets/vendors/mdi/css/materialdesignicons.min.css" />
    <link rel="stylesheet" href="~/purple/assets/vendors/css/vendor.bundle.base.css" />
    <link rel="stylesheet" href="~/purple/assets/css/style.css" />
</head>
<body>
    <div class="loader"></div>
    <div class="app-container app-theme-white body-tabs-shadow fixed-sidebar fixed-header">
        <!-- header and sidebar: unchanged -->
        <div class="app-main__outer">
            <div class="app-main__inner">
                <div class="col-md-8 grid-margin stretch-card">
                    <div class="card">
                        <div class="card-body">
                            <h4 class="card-title mb-2">Kategori Kaydı</h4>
                            <p class="card-description mb-4">Yeni kategori bilgilerini giriniz</p>

                            @using (Html.BeginForm("Create_C", "Category", FormMethod.Post, new { @class = "forms-sample", enctype = "multipart/form-data", data_parsley_validate = "true" }))
                            {
                                @Html.AntiForgeryToken()

                                <div class="row g-3 mb-4">
                                    <div class="col-md-6">
                                        @Html.LabelFor(model => model.Kategori1, "Kategori Adı", htmlAttributes: new { @class = "form-label" })
                                        @Html.TextBoxFor(model => model.Kategori1, new { @class = "form-control", required = "required", minlength = "1", maxlength = "32" })
                                        @Html.ValidationMessageFor(model => model.Kategori1, "", new { @class = "text-danger" })
                                    </div>
                                </div>

                                <hr class="my-4 border-top border-2 border-secondary" />
                                <button type="submit" class="btn btn-gradient-primary">Kaydet</button>
                                <a href="@Url.Action("Index_C", "Category")" class="btn btn-light ms-2">Geri Dön</a>
                            }

                        </div>
                    </div>
                </div>
            </div>
            <!-- footer: unchanged -->
        </div>
    </div>
</body>
</html>