@model IEnumerable<MDK.Models.Musteri>

@{
    ViewBag.Title = "Index_MU";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Musteri Listesi</title>
    <link rel="stylesheet"
          href="/purple/vendors/mdi/css/materialdesignicons.min.css">
    <link rel="stylesheet"
          href="/purple/assets/vendors/css/vendor.bundle.base.css">
    <link rel="stylesheet" href="/purple/assets/css/style.css" />

    <!-- SweetAlert2 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.3/dist/sweetalert2.min.css" rel="stylesheet">
</head>

<body>
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Müşteri Listesi</h4>
            <table class="table">
                <thead>
                    <tr>
                        <th>No</th>
                        <th>Ad</th>
                        <th>Soyad</th>
                        <th>Telefon</th>
                        <th>Detaylar</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var customer in Model)
                    {
                        <tr>
                            <td>@customer.Id</td>
                            <td>@customer.Ad</td>
                            <td>@customer.Soyad</td>
                            <td>@customer.Telefon.Telefon_No</td>
                            <td>
                                <div class="d-flex">
                                    <button type="submit" class="btn btn-primary btn-sm btn-icon-split p-1 mx-1"
                                            onclick="window.location.href = '/Customer/Details_MU/@customer.Id'">
                                        Görüntüle
                                    </button>

                                    <button type="submit" class="btn btn-gradient-warning btn-sm btn-icon-split p-1 mx-1"
                                            onclick="window.location.href = '/Customer/Edit_MU/@customer.Id'">
                                        Dunzenle
                                    </button>

                                    <button type="button"
                                            class="btn btn-danger btn-sm btn-icon-split p-1 mx-1 pr-3 pl-3"
                                            onclick="confirmDelete(@customer.Id)">
                                        Sil
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="d-flex justify-content-end mt-4">
                <a href="@Url.Action("ExportPdf_MU", "Customer")"
                   class="btn btn-gradient-primary me-2">
                    <i class="mdi mdi-content-save"></i> PDF Oluştur
                </a>
            </div>
        </div>
    </div>

    <!-- SweetAlert2 JS -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.7.3/dist/sweetalert2.all.min.js"></script>

    <script type="text/javascript">
        function confirmDelete(musteriId) {
            // SweetAlert confirmation
            Swal.fire({
                title: 'Silmek Istediginden Emin misin? ',
                text: 'Bu işlemi geri alamazsın!',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: 'Evet, Sil',
                cancelButtonText: 'Hayır, iptal et'
            }).then((result) => {
                if (result.isConfirmed) {
                    // If confirmed, navigate to the delete URL
                    window.location.href = '/Customer/Delete_MU/' + musteriId; // Fixed typo here
                }
            });
        }
    </script>

</body>

</html>