
@{
    ViewBag.Title = "Create_EM";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@model MDK.Models.Personel

<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Personel Ekleme</title>
    <link rel="stylesheet"
          href="/purple/assets/vendors/mdi/css/materialdesignicons.min.css">
    <link rel="stylesheet"
          href="/purple/assets/vendors/css/vendor.bundle.base.css">
    <link rel="stylesheet"
          href="/purple/assets/css/style.css" />
</head>

<body>
    <div class="col-md-8 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Personel Bilgileri Ekleme</h4>

                <form action="/Employee/Create_EM" method="post" class="forms-sample">

                    <div class="row">
                        <div class="form-group col-md-6">
                            <label for="Ad">Ad</label>
                            <input type="text" class="form-control" id="Ad" name="Ad" placeholder="Ad" required />
                        </div>
                        <div class="form-group col-md-6">
                            <label for="Soyad">Soyad</label>
                            <input type="text" class="form-control" id="Soyad" name="Soyad" placeholder="Soyad" required />
                        </div>
                    </div>

                    <div class="row">
                        <div class="form-group col-md-6">
                            <label for="Gmail.Gmail1">E-Posta</label>
                            <input type="email" class="form-control" id="Gmail.Gmail1" name="Gmail.Gmail1" placeholder="email@example.com" required />
                        </div>
                        <div class="form-group col-md-6">
                            <label for="Adres.Adres_Bilgisi">Adres</label>
                            <input type="text" class="form-control" id="Adres.Adres_Bilgisi" name="Adres.Adres_Bilgisi" placeholder="Adres" required />
                        </div>
                    </div>

                    <div class="row">
                        <div class="form-group col-md-6">
                            <label for="Tc_Bilgileri.Tc_No">TC No</label>
                            <input type="text" class="form-control" id="Tc_Bilgileri.Tc_No" name="Tc_Bilgileri.Tc_No" placeholder="TC" maxlength="11"
                                   oninput="this.value = this.value.replace(/[^0-9]/g, '')" required />
                        </div>
                        <div class="form-group col-md-6">
                            <label for="Telefon.Telefon_No">Telefon</label>
                            <input type="tel" class="form-control" id="Telefon.Telefon_No" name="Telefon.Telefon_No" placeholder="05555555555"
                                   maxlength="11" oninput="this.value = this.value.replace(/[^0-9]/g, '')" required />
                        </div>
                    </div>

                    <div class="row">
                        <div class="form-group col-md-6">
                            <label for="Yas">Yas</label>
                            <input type="number" class="form-control" id="Yas" name="Yas" placeholder="0" min="0" required />
                        </div>
                        <div class="form-group col-md-6">
                            <label for="Maas">Maas</label>
                            <input type="number" class="form-control" id="Maas" name="Maas" placeholder="0" min="0" required />
                        </div>
                    </div>

                    <div class="row">
                        <div class="form-group col-md-6">
                            <label for="Medeni_Durumu" class="form-label">Medeni Durum</label>
                            <select id="Medeni_Durumu" name="Medeni_Durumu" class="form-select" required>
                                <option value="">Seciniz</option>
                                <option value="Bekar">Bekar</option>
                                <option value="Evli">Evli</option>
                            </select>
                        </div>
                        <div class="form-group col-md-6">
                            <label for="Cinsiyet">Cinsiyet</label>
                            <select id="Cinsiyet" name="Cinsiyet" class="form-select" required>
                                <option value="">Seciniz</option>
                                <option value="true">Erkek</option>
                                <option value="false">Kadin</option>
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="form-group col-md-6">
                            <label for="Cocuk_Sayisi">Cocuk Sayisi</label>
                            <input type="number" class="form-control" id="Cocuk_Sayisi" name="Cocuk_Sayisi" placeholder="0" min="0" required />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-gradient-primary me-2">Ekle</button>
                    <a href="/Employee/Index_EM" class="btn btn-light">İptal</a>
                </form>
            </div>
        </div>
    </div>
</body>
</html>