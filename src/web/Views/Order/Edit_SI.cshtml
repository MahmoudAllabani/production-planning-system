@model MDK.Models.Siparis

@{
    ViewBag.Title = "Sipariş Düzenle";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var formData = TempData["FormData"] as Dictionary<string, object>;
}

<!DOCTYPE html>
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sipariş Düzenle</title>
    <link rel="stylesheet" href="/purple/assets/vendors/mdi/css/materialdesignicons.min.css">
    <link rel="stylesheet" href="/purple/assets/vendors/css/vendor.bundle.base.css">
    <link rel="stylesheet" href="/purple/assets/css/style.css" />
</head>
<body>
    <div class="col-md-8 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Sipariş Düzenle</h4>
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger">
                        @Html.Raw(TempData["ErrorMessage"])
                    </div>
                }
                <form action="/Order/Edit_SI" method="post" class="forms-sample">
                    @Html.HiddenFor(m => m.Id)
                    <div class="row">
                        <div class="form-group col-md-6">
                            <label for="musteri" class="form-label">Müşteri</label>
                            <select class="form-select" id="musteri" name="musteri" required>
                                <option value="">Seçiniz</option>
                                @foreach (var musteri in ViewBag.customers)
                                {
                                    <option value="@musteri.Id" @(formData != null && formData.ContainsKey("musteri") && Convert.ToInt32(formData["musteri"]) == musteri.Id ? "selected" : (Model.Musteri_FK == musteri.Id ? "selected" : ""))>@musteri.Ad @musteri.Soyad</option>
                                }
                            </select>
                        </div>
                        <div class="form-group col-md-6">
                            <label for="urun" class="form-label">Ürün</label>
                            <select class="form-select" id="urun" name="urun" required>
                                <option value="">Seçiniz</option>
                                @foreach (var urun in ViewBag.products)
                                {
                                    <option value="@urun.Id" data-kapasite="@urun.Fabrika_Kapasitesi" @(formData != null && formData.ContainsKey("urun") && Convert.ToInt32(formData["urun"]) == urun.Id ? "selected" : (Model.Urun_FK == urun.Id ? "selected" : ""))>@ViewBag.productDisplayNames[urun.Id]</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="form-group col-md-6">
                            <label for="miktar" class="form-label">Miktar</label>
                            <input type="number" class="form-control" id="miktar" name="miktar" min="1" max="1000000" value="@(formData != null && formData.ContainsKey("miktar") ? formData["miktar"] : Model.Miktar)" required />
                        </div>
                        <div class="form-group col-md-6">
                            <label for="mesai" class="form-label">Mesai Saati</label>
                            <input type="number" class="form-control" id="mesai" name="mesai" min="0" max="16" value="@(formData != null && formData.ContainsKey("mesai") ? formData["mesai"] : Model.Mesai)" required />
                        </div>
                    </div>
                    <div class="row">
                        <div class="form-group col-md-6">
                            <label for="TTT" class="form-label">Teslim Tarihi</label>
                            <input type="datetime-local" class="form-control" id="TTT" name="TTT" value="@(formData != null && formData.ContainsKey("TTT") ? formData["TTT"] : (Model.Teslim_Tarihi?.ToString("yyyy-MM-ddTHH:mm")))" required />
                            <small id="tahminiTeslimTarihi" class="form-text text-muted"></small>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-gradient-primary me-2">Güncelle</button>
                    <a href="/Order/Index_SI" class="btn btn-light">İptal</a>
                </form>
            </div>
        </div>
    </div>
</body>
</html>