
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <!-- Required meta tags -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Purple Admin</title>
    <!-- plugins:css -->
    <link rel="stylesheet" href="~/purple/assets/vendors/mdi/css/materialdesignicons.min.css">
    <link rel="stylesheet" href="~/purple/assets/vendors/css/vendor.bundle.base.css">
    <!-- endinject -->
    <!-- Plugin css for this page -->
    <!-- End plugin css for this page -->
    <!-- inject:css -->
    <!-- endinject -->
    <!-- Layout styles -->
    <link rel="stylesheet" href="~/purple/assets/css/style.css">
    <!-- End layout styles -->
    <link rel="shortcut icon" href="~/purple/assets/images/favicon.ico" />

</head>

<body>
    <div class="container-scroller">
        <div class="container-fluid page-body-wrapper full-page-wrapper">
            <div class="content-wrapper d-flex align-items-center auth">
                <div class="row flex-grow">
                    <div class="col-lg-4 mx-auto">
                        <div class="auth-form-light text-left p-5">
                            <div class="brand-logo">
                                <img style="position:relative;right:-20%;width:60%" src="~/purple/assets/images/logo4.svg" />
                            </div>
                            <h4>Giris</h4>
                            <form class="pt-3" method="POST" novalidate="" autocomplete="off" action="/Auth/Login">
                                <div class="form-group">
                                    <input type="email" id="email" class="form-control form-control-lg" name="email" value="" required autofocus placeholder="E-Mail Adresi">
                                    <div class="invalid-feedback">
                                        Email geçersiz
                                    </div>
                                </div>
                                <div class="form-group">
                                    <input type="password" class="form-control form-control-lg" id="password" name="password" required minlength="8" placeholder="Sifre">
                                    <div class="invalid-feedback">
                                        Şifre en az 8 karakterden oluşmalıdır
                                    </div>
                                </div>
                                <div class="mt-3">
                                    <button type="submit" class="btn btn-block btn-gradient-primary btn-lg font-weight-medium auth-form-btn">
                                        Giriş Yap
                                    </button>

                                </div>
                                <div class="my-2 d-flex justify-content-between align-items-center">
                                    <div class="form-check">
                                        <label class="form-check-label text-muted">
                                            <input type="checkbox" class="form-check-input"> Oturumu Acik Tut
                                        </label>
                                    </div>
                                    <a href="/Auth/Newpassword" class="auth-link text-black">Sifreyi Unuttum</a>
                                </div>
                            </form>
                        </div>
                        <div class="text-center mt-5 text-muted">
                            Copyright &copy; 2025 &mdash; MDK - Üretim Planlama Yazılımı
                        </div>
                    </div>
                </div>
            </div>
            <!-- content-wrapper ends -->
        </div>
        <!-- page-body-wrapper ends -->
    </div>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            Swal.fire({
                icon: 'error',
                title: 'Hata',
                text: 'Girilen bilgiler hatalıdır. Lütfen tekrar giriniz.'
            });
        });
    </script>


    <script src="~/Content/Auth/js/login.js"></script>
    <script src="~/purple/assets/vendors/js/vendor.bundle.base.js"></script>
    <!-- endinject -->
    <!-- Plugin js for this page -->
    <!-- End plugin js for this page -->
    <!-- inject:js -->
    <script src="~/purple/assets/js/off-canvas.js"></script>
    <script src="~/purple/assets/js/hoverable-collapse.js"></script>
    <script src="~/purple/assets/js/misc.js"></script>
</body>
</html>